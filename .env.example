# ==============================
# Database
# ==============================
DATABASE_URL="postgresql://tigernum:tigernum_password@localhost:5432/tigernum_db?schema=public"
DB_NAME=tigernum_db
DB_USER=tigernum
DB_PASSWORD=tigernum_password

# ==============================
# Redis
# ==============================
REDIS_URL=redis://default:redis_password@localhost:6379
REDIS_PASSWORD=redis_password

# ==============================
# Application
# ==============================
NODE_ENV=development
PORT=3000
APP_NAME=TigerNumApp
APP_URL=http://localhost:3000

# ==============================
# JWT
# ==============================
JWT_SECRET=change-me-to-a-very-long-random-secret
JWT_EXPIRES_IN=30d

# ==============================
# Telegram Bot
# ==============================
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_WEBHOOK_URL=

# ==============================
# SMS Providers
# ==============================
HERO_SMS_API_URL=https://api.hero-sms.com
HERO_SMS_API_KEY=your_hero_sms_key
HERO_SMS_API_SECRET=

TIGER_SMS_API_URL=https://api.tiger-sms.com
TIGER_SMS_API_KEY=your_tiger_sms_key
TIGER_SMS_API_SECRET=

# ==============================
# Rate Limiting
# ==============================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ==============================
# Logging
# ==============================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ==============================
# Polling
# ==============================
POLL_INTERVAL_MS=5000
MAX_POLL_ATTEMPTS=24
ORDER_EXPIRY_MINUTES=20

# ==============================
# Security
# ==============================
CORS_ORIGIN=*
ENCRYPTION_KEY=change-me-to-a-very-long-secure-key
